# ============================================================
# Snow → Terraform Provisioning Agent  –  .env.example
# Copy to .env and fill in your values
# ============================================================

# ── Azure OpenAI (reuse existing resource) ──────────────────
AZURE_OPENAI_ENDPOINT=https://snate-mkpwns1j-eastus2.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-nano
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MODEL_NAME=gpt-4.1-nano

# Auth: choose one approach
AZURE_OPENAI_USE_AZURE_AD=true
AZURE_OPENAI_API_KEY=

# ── ServiceNow MCP ───────────────────────────────────────────
# Command to start the ServiceNow MCP server.
# ServiceNow's official AI Kit: https://www.npmjs.com/package/@servicenow/now-ai-kit
SNOW_MCP_COMMAND=npx -y @servicenow/now-ai-kit@latest

SNOW_INSTANCE=https://devXXXXXX.service-now.com
SNOW_USER=admin
SNOW_PASSWORD=your-snow-password

# ── GitHub MCP ───────────────────────────────────────────────
GITHUB_MCP_COMMAND=npx -y @modelcontextprotocol/server-github

# GitHub Personal Access Token — needs: repo, workflow scopes
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# GitHub org/user and demo Terraform repo
GITHUB_ORG=natesanshreyas
GITHUB_TERRAFORM_REPO=terraform-modules-demo

# ── Azure MCP ────────────────────────────────────────────────
# Full path to npx is recommended in case nvm is used
AZURE_MCP_SERVER_COMMAND=/home/snatesan/.nvm/versions/node/v20.20.0/bin/npx -y @azure/mcp@latest server start

# Target Azure subscription for resource checks
AZURE_SUBSCRIPTION_ID=68837237-5a48-41a9-bed4-947f5c277684
